generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("customer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  reviews      Review[]
}

model Product {
  id          Int         @id @default(autoincrement())
  title       String
  slug        String      @unique
  description String
  price       Int
  category    String
  imageUrls   String
  featured    Boolean     @default(false)
  stock       Int         @default(100)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id               Int         @id @default(autoincrement())
  orderReference   String      @unique
  userId           Int
  email            String
  firstName        String
  lastName         String
  addressLine1     String
  addressLine2     String?
  city             String
  postalCode       String
  country          String
  status           String      @default("pending")
  subtotal         Int
  discountTotal    Int
  shippingTotal    Int
  total            Int
  couponCode       String?
  pricingBreakdown String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  title     String
  imageUrl  String
  unitPrice Int
  quantity  Int
  lineTotal Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Coupon {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  type       String
  amount     Int
  expiresAt  DateTime?
  usageLimit Int?
  usageCount Int       @default(0)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model DiscountRule {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  ruleType     String
  threshold    Int
  discountType String
  amount       Int
  priority     Int       @default(100)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  userId    Int
  rating    Int
  title     String
  body      String
  tag       String   @default("Cliente verificato")
  status    String   @default("approved")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
