generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("customer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  reviews      Review[]
  checkoutSessions CheckoutSession[]
  backInStockSubscriptions BackInStockSubscription[]
}

model Product {
  id          Int         @id @default(autoincrement())
  title       String
  slug        String      @unique
  sku         String?     @unique
  description String
  status      String      @default("active")
  price       Int
  discountPrice Int?
  priceA4     Int?
  discountPriceA4 Int?
  priceA3     Int?
  discountPriceA3 Int?
  costPrice   Int         @default(0)
  hasA4       Boolean     @default(true)
  hasA3       Boolean     @default(false)
  category    String
  imageUrls   String
  manualBadges String    @default("[]")
  featured    Boolean     @default(false)
  stock       Int         @default(100)
  lowStockThreshold Int   @default(5)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  variants    ProductVariant[]
  productTags ProductTag[]
  productCollections ProductCollection[]
  backInStockSubscriptions BackInStockSubscription[]
}

model ProductVariant {
  id                Int        @id @default(autoincrement())
  productId         Int
  title             String
  key               String
  sku               String?    @unique
  optionsJson       String     @default("[]")
  price             Int
  discountPrice     Int?
  costPrice         Int        @default(0)
  stock             Int        @default(0)
  lowStockThreshold Int        @default(5)
  position          Int        @default(0)
  isDefault         Boolean    @default(false)
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  product           Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  backInStockSubscriptions BackInStockSubscription[]

  @@unique([productId, key])
}

model BackInStockSubscription {
  id         Int             @id @default(autoincrement())
  userId     Int
  productId  Int
  variantId  Int?
  email      String
  status     String          @default("pending")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  restockedAt DateTime?
  notifiedAt DateTime?
  cancelledAt DateTime?
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([userId, productId, variantId])
  @@index([status, productId, variantId])
}

model Tag {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    ProductTag[]
}

model ProductTag {
  productId Int
  tagId     Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model Collection {
  id          Int                 @id @default(autoincrement())
  title       String
  slug        String              @unique
  description String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    ProductCollection[]
}

model ProductCollection {
  productId    Int
  collectionId Int
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model Order {
  id               Int         @id @default(autoincrement())
  orderReference   String      @unique
  userId           Int
  email            String
  firstName        String
  lastName         String
  phone            String?
  addressLine1     String
  addressLine2     String?
  streetNumber     String?
  staircase        String?
  apartment        String?
  floor            String?
  intercom         String?
  deliveryNotes    String?
  city             String
  region           String?
  postalCode       String
  country          String
  status           String      @default("pending")
  fulfillmentStatus String     @default("processing")
  shippingMethod   String?
  shippingCarrier  String?
  shippingLabel    String?
  shippingStatus   String?
  subtotal         Int
  discountTotal    Int
  shippingCost     Int?
  shippingTotal    Int
  total            Int
  couponCode       String?
  trackingNumber   String?
  trackingUrl      String?
  shippingCreatedAt DateTime?
  dhlShipmentReference String?
  labelUrl         String?
  shippingError    String?
  pricingBreakdown String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model CheckoutSession {
  id               Int      @id @default(autoincrement())
  orderReference   String   @unique
  userId           Int
  email            String
  firstName        String
  lastName         String
  phone            String?
  addressLine1     String
  addressLine2     String?
  streetNumber     String?
  staircase        String?
  apartment        String?
  floor            String?
  intercom         String?
  deliveryNotes    String?
  city             String
  region           String?
  postalCode       String
  country          String
  status           String   @default("pending")
  shippingMethod   String?
  subtotal         Int
  discountTotal    Int
  shippingLabel    String?
  shippingCost     Int?
  shippingTotal    Int
  total            Int
  couponCode       String?
  shippingCarrier  String?
  trackingNumber   String?
  pricingBreakdown String
  itemsSnapshot    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  completedAt      DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  variantId Int?
  title     String
  imageUrl  String
  format    String?
  variantLabel String?
  variantSku String?
  unitPrice Int
  unitCost  Int     @default(0)
  quantity  Int
  lineTotal Int
  costTotal Int     @default(0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  createdAt DateTime @default(now())
}

model Coupon {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  type       String
  amount     Int
  expiresAt  DateTime?
  usageLimit Int?
  usageCount Int       @default(0)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model DiscountRule {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  ruleType     String
  threshold    Int
  discountType String
  amount       Int
  priority     Int       @default(100)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(cuid())
  userId    Int
  rating    Int
  title     String
  body      String
  tag       String   @default("Cliente verificato")
  status    String   @default("approved")
  showOnHomepage Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
