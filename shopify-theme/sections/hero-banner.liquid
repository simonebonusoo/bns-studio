<section class="hero-banner">
  <div class="page-shell">
    <div class="hero-banner__content">
      {% if section.settings.eyebrow != blank %}
        <p class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      <div class="hero-banner__actions">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a class="button button--primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "BNS Studio Shop" },
    { "type": "textarea", "id": "heading", "label": "Titolo", "default": "Poster, stampe e oggetti con l'estetica BNS Studio." },
    { "type": "textarea", "id": "subheading", "label": "Sottotitolo", "default": "Collezioni visive pensate per scrivanie, studi creativi e spazi personali." },
    { "type": "text", "id": "primary_label", "label": "CTA primaria", "default": "Scopri la collezione" },
    { "type": "url", "id": "primary_link", "label": "Link CTA primaria" },
    { "type": "text", "id": "secondary_label", "label": "CTA secondaria", "default": "Chi siamo" },
    { "type": "url", "id": "secondary_link", "label": "Link CTA secondaria" }
  ],
  "presets": [
    { "name": "Hero banner" }
  ]
}
{% endschema %}
